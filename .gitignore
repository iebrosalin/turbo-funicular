```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Database
instance/*.db

# Environment variables
.env
.env.local
*.env.*

# Dependencies
venv/
.venv/
pip-log.txt
pipenv.lock

# Logs
*.log

# Coverage reports
.coverage
htmlcov/
.coveragerc

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db
```