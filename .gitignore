```gitignore
# Python compiled files
*.pyc
__pycache__/

# Database files
instance/*.db

# Environment files
.env
.env.local
*.env.*

# Dependencies
venv/
.venv/
node_modules/

# Logs and temporary files
*.log
*.tmp

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# OS specific
.DS_Store
Thumbs.db
```